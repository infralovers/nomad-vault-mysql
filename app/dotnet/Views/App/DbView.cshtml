@model NomadVaultMySqlDotnet.Models.RecordsPageModel

<br>
<section>
  <div class="container" style="overflow-x:auto">
    <div class="tile is-ancestor">
      <div class="tile is-vertical is-parent">
        <p class="title" style="font-family:gilmer-web, Gilmer, Geneva, Tahoma, Helvetica, Verdana, sans-serif;">Raw Database Results</p>
        <p style="color:#363942;">SELECT * FROM customers;</p>
      </div>
    </div>

    <table class="table is-bordered is-striped is-narrow is-hoverable is-fullwidth">
      <thead>
        <tr>
          <th>cust_no</th>
          <th>last_name</th>
          <th>first_name</th>
          <th>birth_date</th>
          <th>social_security_number</th>
          <th>credit_card_number</th>
          <th>address</th>
          <th>salary</th>
          <th>create_date</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var record in Model.Results)
        {
          <tr>
            <td>@record.CustomerNumber</td>
            <td>@record.LastName</td>
            <td>@record.FirstName</td>
            <td>@record.BirthDate</td>
            <td>@record.Ssn</td>
            <td>@record.Ccn</td>
            <td>@record.Address</td>
            <td>@record.Salary</td>
            <td>@record.CreateDate</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</section>
