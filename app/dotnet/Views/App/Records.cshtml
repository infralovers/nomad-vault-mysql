@model NomadVaultMySqlDotnet.Models.RecordsPageModel

<p><br></p>
<div class="tile is-ancestor">
  <div class="tile is-vertical is-parent">
    <p class="title" style="font-family:gilmer-web, Gilmer, Geneva, Tahoma, Helvetica, Verdana, sans-serif;">Application Data</p>
    <p style="color:#363942;">This table represents the application view. Transit protects data in motion and keeps cryptographic operations in Vault.</p>
  </div>
</div>

@if (Model.RecordAdded)
{
  <div class="notification is-success">Record successfully added</div>
}

@if (Model.RecordUpdated)
{
  <div class="notification is-info">Record successfully updated</div>
}

<table class="table is-bordered is-striped is-narrow is-hoverable is-fullwidth">
  <thead>
    <tr>
      <th>Cust #</th>
      <th>First</th>
      <th>Last</th>
      <th>Date of Birth</th>
      <th>SSN</th>
      <th>Credit Card Number</th>
      <th>Address</th>
      <th>Salary</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    @foreach (var record in Model.Results)
    {
      <tr>
        <td>@record.CustomerNumber</td>
        <td>@record.FirstName</td>
        <td>@record.LastName</td>
        <td>@record.BirthDate</td>
        <td>@record.Ssn</td>
        <td>@record.Ccn</td>
        <td>@record.Address</td>
        <td>@record.Salary</td>
        <td>@record.CreateDate</td>
        <td><a class="button is-small is-warning" href="/update?cust_no=@record.CustomerNumber">Edit</a></td>
      </tr>
    }
  </tbody>
</table>
